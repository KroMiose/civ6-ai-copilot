    </Replace>
    <Replace Tag="LOC_CIV6_AI_COPILOT_TOOLTIP_ICON_WORLD_RANKINGS" Language="zh_Hans_CN">
      <Text>LaunchBar_Hook_WorldRankings。适合全局比较，但竞技意味更强。</Text>
    </Replace>

    <Replace Tag="LOC_CIV6_AI_COPILOT_TOOLTIP_ICON_CITY_STATES" Language="en_US">
